{
  "info": {
    "name": "todo-cqrs API",
    "_postman_id": "f53f2cec-5297-4545-b0de-482d994ab3d3",
    "description": "Collection test day du 5 endpoint command/query cho Todo CQRS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "todoId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Command - Create Todo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Hoc CQRS\",\n  \"description\": \"Hoan thanh bai tap CQRS + ES\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/todos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json && json.id) {",
              "    pm.collectionVariables.set(\"todoId\", json.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Query - Get All Todos",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/todos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos"
          ]
        }
      }
    },
    {
      "name": "Query - Get Todo By Id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/todos/{{todoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos",
            "{{todoId}}"
          ]
        }
      }
    },
    {
      "name": "Command - Update Todo",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Hoc CQRS - updated\",\n  \"description\": \"Da update bang endpoint command\",\n  \"completed\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/todos/{{todoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos",
            "{{todoId}}"
          ]
        }
      }
    },
    {
      "name": "Command - Delete Todo",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/todos/{{todoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "todos",
            "{{todoId}}"
          ]
        }
      }
    }
  ]
}
